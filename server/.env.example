# ====== OptimusAutomate Blog App — Backend Environment ======
# Copy this file to ".env" and fill in your real values.
# NEVER commit the real .env file — it is gitignored.

# Server
PORT=5000
NODE_ENV=development

# Frontend URL (used for CORS whitelist)
CLIENT_URL=http://localhost:5173

# MongoDB Atlas — get from Atlas dashboard "Connect > Drivers"
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/blogapp?retryWrites=true&w=majority

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Access tokens are short-lived (15m). Refresh tokens last 7d and are rotated.
JWT_SECRET=replace_with_min_32_char_random_hex_string
JWT_REFRESH_SECRET=replace_with_a_DIFFERENT_min_32_char_random_hex_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Cloudinary — get from cloudinary.com console "Dashboard"
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Upload limits
MAX_UPLOAD_MB=5
